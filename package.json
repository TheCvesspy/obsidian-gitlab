{
  "name": "obsidian-gitlab-plugin",
  "version": "2.0.0",
  "description": "Connect Obsidian vault sub-trees to GitLab repositories with full Git functionality",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "gitlab",
    "git",
    "sync",
    "version-control"
  ],
  "author": "Quill of the Weavers",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.8",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "isomorphic-git": "^1.25.0"
  }
}
